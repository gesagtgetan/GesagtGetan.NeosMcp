{
  "name": "gesagtgetan/neos-mcp",
  "description": "MCP (Model Context Protocol) server for Neos Content Repository — gives LLMs structured access to content",
  "type": "neos-package",
  "require": {
    "php": "^8.3",
    "league/oauth2-server": "^8.5",
    "neos/neos": "^9.1",
    "php-mcp/server": "^3.3"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.86",
    "phpstan/phpstan": "^2.1",
    "phpstan/phpstan-phpunit": "^2.0",
    "phpstan/phpstan-strict-rules": "^2.0",
    "phpunit/phpunit": "^10.5",
    "squizlabs/php_codesniffer": "^4.0"
  },
  "suggest": {
    "gesagtgetan/neos-mcp-images": "Adds MCP tools to find images in the media library by alt-text and assign them to image properties on nodes"
  },
  "autoload": {
    "psr-4": {
      "GesagtGetan\\NeosMcp\\": "Classes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "GesagtGetan\\NeosMcp\\Tests\\": "Tests/"
    }
  },
  "extra": {
    "neos": {
      "package-key": "GesagtGetan.NeosMcp"
    }
  }
}
